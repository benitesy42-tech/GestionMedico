{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist/ProyectoGestionMedico/browser",
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}